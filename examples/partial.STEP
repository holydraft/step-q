ISO-10303-21;
HEADER;
FILE_DESCRIPTION (( 'STEP file with STEP-Q metadata' ),
	'1' );
FILE_NAME ('partial.STEP',
	'2026-05-27T00:00:00',
	( 'holydraft' ),
	( 'holydraft' ),
	'STEP-Q',
	'partial example',
	'' );
FILE_SCHEMA (( 'AUTOMOTIVE_DESIGN' ));
ENDSEC;
DATA;
#25 = PROPERTY_SET ( 'STEP-Q', $, $ ) ;
#26 = DESCRIPTIVE_REPRESENTATION_ITEM ( 'Q_PRODUCT_TYPE', 'turning' ) ;
#27 = DESCRIPTIVE_REPRESENTATION_ITEM ( 'Q_MATERIAL', 'Beliebiger Stahl' ) ;
#28 = DESCRIPTIVE_REPRESENTATION_ITEM ( 'Q_QUANTITY', '5' ) ;
#29 = DESCRIPTIVE_REPRESENTATION_ITEM ( 'Q_THREAD_TYPE', 'isometric' ) ;
#30 = DESCRIPTIVE_REPRESENTATION_ITEM ( 'Q_TEST_REPORT', 'en_10204_3_1' ) ;
#31 = DESCRIPTIVE_REPRESENTATION_ITEM ( 'Q_SPECIAL_THREAD_NOTE', 'THREAD RELIEF PER DWG NOTE 7' ) ;
#10 = APPLICATION_CONTEXT ( 'automotive design' ) ;
#11 = APPLICATION_PROTOCOL_DEFINITION ( 'international standard', 'automotive_design', 1994, #10 ) ;
#12 = MECHANICAL_CONTEXT ( '', #10, 'mechanical' ) ;
#13 = PRODUCT ( 'HD-2026-002', 'STEP-Q turned insert', '', ( #12 ) ) ;
#14 = PRODUCT_DEFINITION_FORMATION ( '1', 'initial', #13 ) ;
#15 = PRODUCT_DEFINITION_CONTEXT ( 'part definition', #10, 'design' ) ;
#16 = PRODUCT_DEFINITION ( 'design', '', #14, #15 ) ;
#17 = PRODUCT_DEFINITION_SHAPE ( '', '', #16 ) ;
#18 = REPRESENTATION_CONTEXT ( '3D', 'shape representation' ) ;
#19 = CARTESIAN_POINT ( 'origin', ( 0., 0., 0. ) ) ;
#20 = DIRECTION ( 'z_axis', ( 0., 0., 1. ) ) ;
#21 = DIRECTION ( 'x_axis', ( 1., 0., 0. ) ) ;
#22 = AXIS2_PLACEMENT_3D ( 'part origin', #19, #20, #21 ) ;
#23 = SHAPE_REPRESENTATION ( 'HD-2026-002', ( #22 ), #18 ) ;
#24 = SHAPE_DEFINITION_REPRESENTATION ( #17, #23 ) ;
ENDSEC;
END-ISO-10303-21;
